# Copy this file to .env and fill in real values. .env is git-ignored.

# RentCast — property records, value & rent AVMs (required for analysis)
# Free tier: 50 calls/month. https://app.rentcast.io/app/api
RENTCAST_API_KEY=your-key-here

# HUD Fair Market Rents (optional; free token, instant)
# https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=

# Census ACS demographics (optional; free key, instant)
# https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# FEMA flood zones need no key.

# Supabase sync (optional) — see README
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
